# F04: only VITE_API_BASE_URL is required for the app shell.
VITE_API_BASE_URL=http://localhost:3000/api
# F05: Google OAuth Client ID (from Google Cloud Console -> Credentials -> OAuth 2.0 Client ID).
# This is the PUBLIC client ID (safe to expose); the secret stays backend-only.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# F10: board auto-polling interval (TanStack Query refetchInterval), seconds.
# Default 30 when unset/invalid (PRD REQ-2.4).
VITE_POLL_INTERVAL_SECONDS=30
