# Slykboard — combined self-host environment template.
# Copy to .env and fill in. NEVER commit real secrets.
#
# For self-host (docker-compose), this single file feeds BOTH the backend service and the
# frontend build. Frontend VITE_* vars are BUILD-TIME: they are inlined into the bundle at
# build time, so changing them requires a REBUILD (not just a container restart).
# In prod, prefer Render env groups / docker env_file over editing this file in place.

# ===========================================================================
# BACKEND
# ===========================================================================

# --- required (app will not start without these) ---
# Frontend origin (CORS allow-list + OAuth redirect trust).
FRONTEND_URL=http://localhost:5173
# Postgres connection string. Use the POOLED url in prod (e.g. Supabase pooler :6543).
DATABASE_URL=postgresql://slyk:slyk@localhost:5432/slykboard
# HS256 signing secret. Generate: openssl rand -base64 48 (min 32 chars).
JWT_SECRET=replace-me-with-a-32-plus-char-random-string
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# 'postmessage' = Google's literal sentinel for the GIS popup auth-code flow (NOT a URL).
GOOGLE_CALLBACK_URL=postmessage

# --- optional ---
PORT=3000
NODE_ENV=development
TZ=UTC
# JWT time-to-live (jose setExpirationTime string). Default '8h'. Sliding window via /me.
JWT_TTL=8h
# Leave empty to allow all Google accounts; set a domain to restrict (G-Suite).
ALLOWED_DOMAIN=

# --- F29 deployment (D4/D8) ---
# Run drizzle migrations on start. true in prod (compose/render); false for local dev.
RUN_MIGRATIONS_ON_START=false
# Direct PG url for migrations (Supabase :5432) — pooled DATABASE_URL can't run DDL.
# Defaults to DATABASE_URL when unset.
DIRECT_DATABASE_URL=

# ===========================================================================
# FRONTEND (VITE_* — build-time, inlined into the bundle)
# ===========================================================================

# Backend origin + /api path.
VITE_API_BASE_URL=http://localhost:3000/api
# PUBLIC Google OAuth client ID (safe to expose); secret stays backend-only.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# Board auto-poll interval, seconds. Default 30. Must be a positive integer.
VITE_POLL_INTERVAL_SECONDS=30
